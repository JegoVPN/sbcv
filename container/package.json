{
  "name": "@sbc/validator-container",
  "version": "0.1.0",
  "description": "sbcv — validator container that runs the sing-box check binary against user-submitted JSON configs.",
  "homepage": "https://sbcv.app",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "docker:build": "docker build -t sbc-validator:dev .",
    "docker:run": "docker run --rm -p 8080:8080 sbc-validator:dev"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22"
  }
}
