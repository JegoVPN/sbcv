{
  "log": {
    "level": "info"
  },
  "dns": {
    "servers": [
      {
        "type": "local",
        "tag": "local-dns"
      },
      {
        "type": "https",
        "tag": "remote-doh",
        "server": "1.1.1.1",
        "server_port": 443,
        "path": "/dns-query",
        "detour": "proxy"
      }
    ],
    "rules": [
      {
        "domain_suffix": [
          "cn"
        ],
        "server": "local-dns"
      }
    ],
    "final": "remote-doh"
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 2080
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    },
    {
      "type": "socks",
      "tag": "hk",
      "server": "127.0.0.1",
      "server_port": 1081
    },
    {
      "type": "socks",
      "tag": "jp",
      "server": "127.0.0.1",
      "server_port": 1082
    },
    {
      "type": "selector",
      "tag": "proxy",
      "outbounds": [
        "hk",
        "jp"
      ],
      "default": "hk"
    }
  ],
  "route": {
    "rules": [
      {
        "domain_suffix": [
          "cn"
        ],
        "outbound": "direct"
      },
      {
        "domain_keyword": [
          "ads"
        ],
        "outbound": "block"
      }
    ],
    "final": "proxy",
    "auto_detect_interface": true,
    "default_domain_resolver": "local-dns"
  }
}
